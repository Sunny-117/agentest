{
  "name": "agentest-kit",
  "version": "0.0.2",
  "description": "⚡️ AI 系统测试框架 — 面向 LLM/Agent 的轻量断言测试工具，AI 界的 Vitest",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "keywords": [
    "ai",
    "testing",
    "llm",
    "agent",
    "assertion",
    "evaluation",
    "vitest",
    "evals"
  ],
  "license": "MIT",
  "author": "Sunny",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sunny-117/agentest.git"
  },
  "homepage": "https://github.com/Sunny-117/agentest#readme",
  "bugs": {
    "url": "https://github.com/Sunny-117/agentest/issues"
  },
  "engines": {
    "node": ">=16"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx playground/simple/run.ts",
    "build": "tsdown",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint ./src",
    "format": "oxfmt format ./src",
    "playground:simple": "tsx playground/simple/run.ts",
    "playground:advanced": "tsx playground/advanced/run.ts",
    "playground": "pnpm run playground:simple && pnpm run playground:advanced"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260505.1",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "tsdown": "^0.21.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
